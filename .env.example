# ─────────────────────────────────────────
# KQXS Live Bot — Biến Môi Trường
# Copy thành .env và điền giá trị
# ─────────────────────────────────────────

# Telegram Bot (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_or_channel_id

# PHP Hosting (Bot gọi PHP proxy để ghi DB)
PHP_HOST=https://yoursite.com
PHP_PUSH_SECRET=quoccheshopai

# Web Dashboard Admin
ADMIN_PASSWORD=your_admin_password_here
SESSION_SECRET=another_random_secret_string

# Timezone
TZ=Asia/Ho_Chi_Minh
