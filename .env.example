# KQXS Live Bot — Environment Variables
# Copy file này thành .env và điền vào
# ══════════════════════════════════════

# Telegram Bot (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_or_channel_id

# PHP Hosting
PHP_HOST=https://yoursite.com
PHP_PUSH_SECRET=quoccheshopai

# Web Dashboard Admin
ADMIN_PASSWORD=your_admin_password_here
SESSION_SECRET=another_random_secret_string

# Timezone
TZ=Asia/Ho_Chi_Minh
